{
  "name": "admin-frontend",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/admin-frontend",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/.next"],
      "options": {
        "command": "next build",
        "cwd": "apps/admin-frontend"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next dev -p 3000",
        "cwd": "apps/admin-frontend"
      }
    },
    "lint": {
      "executor": "@nx/eslint:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/admin-frontend/**/*.{ts,tsx,js,jsx}"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/apps/admin-frontend"],
      "options": {
        "jestConfig": "apps/admin-frontend/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "container": {
      "executor": "@nx-tools/nx-container:build",
      "dependsOn": ["build"],
      "options": {
        "push": false,
        "engine": "docker",
        "metadata": {
          "images": ["polydom/admin-frontend"],
          "load": true,
          "tags": [
            "type=sha,prefix=sha-",
            "type=ref,event=branch"
          ]
        }
      }
    }
  },
  "tags": ["frontend", "next", "admin"]
}
