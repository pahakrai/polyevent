{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "../../..",
    "outDir": "dist",
    "noEmit": false,
    "strictPropertyInitialization": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": false,
    "isolatedModules": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/**/*.spec.ts"]
}
