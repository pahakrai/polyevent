{
  "name": "auth-service",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "start": "ts-node -r tsconfig-paths/register --project tsconfig.json src/main.ts",
    "start:dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register --project tsconfig.json src/main.ts",
    "build": "nest build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "db:generate": "drizzle-kit generate --config=src/database/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=src/database/drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=src/database/drizzle.config.ts",
    "db:push": "drizzle-kit push --config=src/database/drizzle.config.ts",
    "db:seed": "tsx src/database/seed.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.9.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^8.0.0",
    "@polydom/kafka-client": "*",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "dotenv": "^16.3.0",
    "drizzle-orm": "^0.30.0",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcryptjs": "^2.4.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/passport-jwt": "^3.0.0",
    "drizzle-kit": "^0.21.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0"
  }
}
