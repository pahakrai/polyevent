{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "removeComments": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "paths": {
      "@polydom/shared-types": ["../../../libs/shared-types/src/index.ts"],
      "@polydom/kafka-client": ["../../../libs/kafka-client/src/index.ts"],
      "@polydom/database-client": ["../../../libs/database-client/src/index.ts"],
      "@polydom/elasticsearch-client": ["../../../libs/elasticsearch-client/src/index.ts"],
      "@polydom/utils": ["../../../libs/utils/src/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
