{
  "name": "agent-service",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "build": "nest build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "db:generate": "drizzle-kit generate --config src/database/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=src/database/drizzle.config.ts",
    "db:push": "drizzle-kit push --config=src/database/drizzle.config.ts",
    "db:seed": "tsx src/database/seed.ts"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^2.0.32",
    "@anthropic-ai/sdk": "^0.88.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-socket.io": "^10.0.0",
    "@nestjs/websockets": "^10.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.0",
    "@langchain/textsplitters": "^1.0.0",
    "@xenova/transformers": "^2.17.0",
    "langchain": "^1.0.0",
    "ai": "^6.0.175",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "dotenv": "^16.3.0",
    "drizzle-orm": "^0.30.0",
    "mammoth": "^1.8.0",
    "multer": "^1.4.5-lts.1",
    "node-sql-parser": "^5.4.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.11.0",
    "rxjs": "^7.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/jest": "^29.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "drizzle-kit": "^0.21.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0"
  }
}
