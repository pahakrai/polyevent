# Agent Service Configuration
AGENT_DATABASE_URL=postgresql://eventbooking:change-me-use-sealed-secrets@localhost:5432/agent_db

# LLM Provider: "deepseek" or "anthropic"
#   - anthropic: Uses Anthropic SDK (can point to DeepSeek's Anthropic-compatible endpoint)
#   - deepseek: Uses OpenAI-compatible SDK (native DeepSeek API)
LLM_PROVIDER=anthropic

# LLM settings (used by both providers)
LLM_MODEL=deepseek-v4-pro
LLM_API_URL=https://api.deepseek.com/anthropic

# API keys — at least one key matching LLM_PROVIDER must be set
LLM_API_KEY=test123
DEEPSEEK_API_KEY=test123
ANTHROPIC_API_KEY=test123

# Server
PORT=3010
NODE_ENV=development
