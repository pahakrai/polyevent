{
  "name": "event-booking-app",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "start": "nx run-many --target=serve --all",
    "build": "nx run-many --target=build --all",
    "test": "nx run-many --target=test --all",
    "lint": "nx run-many --target=lint --all",
    "format": "nx format:write",
    "dev": "docker compose up --build",
    "dev:down": "docker compose down",
    "dev:infra": "docker compose -f docker-compose.infra.yml up -d",
    "dev:infra:down": "docker compose -f docker-compose.infra.yml down",
    "k8s:apply": "kubectl apply -k kubernetes/overlays/production",
    "k8s:delete": "kubectl delete -k kubernetes/overlays/production",
    "k8s:apply:staging": "kubectl apply -k kubernetes/overlays/staging",
    "k8s:delete:staging": "kubectl delete -k kubernetes/overlays/staging",
    "k8s:dev:up": "docker compose -f docker-compose.infra.yml up -d && kubectl apply -f kubernetes/local/ --recursive",
    "k8s:dev:down": "kubectl delete -f kubernetes/local/ --recursive && docker compose -f docker-compose.infra.yml down",
    "db:generate:auth": "cd apps/nestjs-services/auth-service && npm run db:generate",
    "db:migrate:auth": "cd apps/nestjs-services/auth-service && npm run db:migrate",
    "db:seed:auth": "cd apps/nestjs-services/auth-service && npm run db:seed",
    "db:studio:auth": "cd apps/nestjs-services/auth-service && npm run db:studio",
    "db:push:auth": "cd apps/nestjs-services/auth-service && npm run db:push",
    "db:generate:user": "cd apps/nestjs-services/user-service && npm run db:generate",
    "db:migrate:user": "cd apps/nestjs-services/user-service && npm run db:migrate",
    "db:seed:user": "cd apps/nestjs-services/user-service && npm run db:seed",
    "db:studio:user": "cd apps/nestjs-services/user-service && npm run db:studio",
    "db:push:user": "cd apps/nestjs-services/user-service && npm run db:push",
    "db:generate:vendor": "cd apps/nestjs-services/vendor-service && npm run db:generate",
    "db:migrate:vendor": "cd apps/nestjs-services/vendor-service && npm run db:migrate",
    "db:seed:vendor": "cd apps/nestjs-services/vendor-service && npm run db:seed",
    "db:studio:vendor": "cd apps/nestjs-services/vendor-service && npm run db:studio",
    "db:push:vendor": "cd apps/nestjs-services/vendor-service && npm run db:push",
    "db:generate:event": "cd apps/nestjs-services/event-service && npm run db:generate",
    "db:migrate:event": "cd apps/nestjs-services/event-service && npm run db:migrate",
    "db:seed:event": "cd apps/nestjs-services/event-service && npm run db:seed",
    "db:studio:event": "cd apps/nestjs-services/event-service && npm run db:studio",
    "db:push:event": "cd apps/nestjs-services/event-service && npm run db:push",
    "db:generate:booking": "cd apps/nestjs-services/booking-service && npm run db:generate",
    "db:migrate:booking": "cd apps/nestjs-services/booking-service && npm run db:migrate",
    "db:seed:booking": "cd apps/nestjs-services/booking-service && npm run db:seed",
    "db:studio:booking": "cd apps/nestjs-services/booking-service && npm run db:studio",
    "db:push:booking": "cd apps/nestjs-services/booking-service && npm run db:push",
    "db:generate:notification": "cd apps/nestjs-services/notification-service && npm run db:generate",
    "db:migrate:notification": "cd apps/nestjs-services/notification-service && npm run db:migrate",
    "db:seed:notification": "cd apps/nestjs-services/notification-service && npm run db:seed",
    "db:studio:notification": "cd apps/nestjs-services/notification-service && npm run db:studio",
    "db:push:notification": "cd apps/nestjs-services/notification-service && npm run db:push",
    "db:generate:analytics": "cd apps/nestjs-services/analytics-service && npm run db:generate",
    "db:migrate:analytics": "cd apps/nestjs-services/analytics-service && npm run db:migrate",
    "db:seed:analytics": "cd apps/nestjs-services/analytics-service && npm run db:seed",
    "db:studio:analytics": "cd apps/nestjs-services/analytics-service && npm run db:studio",
    "db:push:analytics": "cd apps/nestjs-services/analytics-service && npm run db:push",
    "db:generate:admin": "cd apps/nestjs-services/admin-service && npm run db:generate",
    "db:migrate:admin": "cd apps/nestjs-services/admin-service && npm run db:migrate",
    "db:seed:admin": "cd apps/nestjs-services/admin-service && npm run db:seed",
    "db:studio:admin": "cd apps/nestjs-services/admin-service && npm run db:studio",
    "db:push:admin": "cd apps/nestjs-services/admin-service && npm run db:push",
    "db:push:neon:auth": "cd apps/nestjs-services/auth-service && cross-env USE_NEON=true npm run db:push",
    "db:push:neon:user": "cd apps/nestjs-services/user-service && cross-env USE_NEON=true npm run db:push",
    "db:push:neon:vendor": "cd apps/nestjs-services/vendor-service && cross-env USE_NEON=true npm run db:push",
    "db:push:neon:event": "cd apps/nestjs-services/event-service && cross-env USE_NEON=true npm run db:push",
    "db:push:neon:all": "npm run db:push:neon:auth && npm run db:push:neon:user && npm run db:push:neon:vendor && npm run db:push:neon:event"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.9.0",
    "dotenv": "^16.3.0",
    "drizzle-kit": "^0.21.0",
    "drizzle-orm": "^0.30.0",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "@nx/cypress": "latest",
    "@nx/eslint": "latest",
    "@nx/jest": "latest",
    "@nx/nest": "latest",
    "@nx/next": "latest",
    "@nx/node": "latest",
    "@nx/react": "latest",
    "@nx/web": "latest",
    "@nx/workspace": "latest",
    "@types/node": "^20.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.0.0",
    "nx": "latest",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0"
  }
}
